              "// Ghi chú : Service gọi AppException(USER_DISABLED) khi user.isEnabled()==false",
              "//           ErrorCode 1022 (ACCOUNT_NOT_VERIFIED) không được dùng ở login flow",
              "// Loại    : Chức năng",
              "// ════════════════════════════════════════════════",
              "",
              "pm.test('TC03 | Status code là 403 Forbidden', function () {",
              "    pm.response.to.have.status(403);",
              "});",
              "",
              "pm.test('TC03 | Response body là JSON hợp lệ', function () {",
              "    pm.response.to.be.json;",
              "});",
              "",
              "const json = pm.response.json();",
              "",
              "pm.test('TC03 | code là 1016 (USER_DISABLED)', function () {",
              "    pm.expect(json.code).to.eql(1016);",
              "});",
              "",
              "pm.test('TC03 | message thông báo tài khoản bị vô hiệu hóa', function () {",
              "    pm.expect(json.message).to.be.a('string').and.not.empty;",
              "});",
              "",
              "pm.test('TC03 | result KHÔNG chứa token', function () {",
              "    pm.expect(json.result).to.be.undefined;",
              "});"
            ]
          }
        }
      ],

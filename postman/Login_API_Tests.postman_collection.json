    {
      "name": "TC08 - Kiểm tra SQL Injection cơ bản",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "// ════════════════════════════════════════════════",
              "// TC08: Kiểm tra SQL Injection cơ bản",
              "// Input   : username=\" or 1=1 --\", password='123'",
              "// Expected: 400 Bad Request, hệ thống không bị crash",
              "// Ghi chú : Spring Data JPA dùng parameterized query nên an toàn.",
              "//           Server phải trả về lỗi (không phải 5xx, không có token)",
              "// Loại    : Bảo mật",
              "// ════════════════════════════════════════════════",
              "",
              "pm.test('TC08 | Hệ thống không bị crash (không phải 5xx)', function () {",
              "    pm.expect(pm.response.code).to.not.be.within(500, 599);",
              "});",
              "",
              "pm.test('TC08 | Status code là 4xx (từ chối request)', function () {",
              "    pm.expect(pm.response.code).to.be.within(400, 499);",
              "});",
              "",
              "pm.test('TC08 | Response body là JSON hợp lệ', function () {",
              "    pm.response.to.be.json;",
              "});",
              "",
              "const json = pm.response.json();",
              "",
              "pm.test('TC08 | code khác 1000 (không đăng nhập được bằng SQL Injection)', function () {",
              "    pm.expect(json.code).to.not.eql(1000);",
              "});",
              "",
              "pm.test('TC08 | result KHÔNG chứa token', function () {",
              "    pm.expect(json.result).to.be.undefined;",
              "});",
              "",
              "pm.test('TC08 | Response không phản chiếu lại payload độc hại (no SQL echo)', function () {",
              "    const body = pm.response.text().toLowerCase();",
              "    pm.expect(body).to.not.include('syntax error');",
              "    pm.expect(body).to.not.include('sql');",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"username\": \"' or 1=1 --\",\n    \"password\": \"123\"\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": {
          "raw": "{{baseUrl}}/auth/login",
          "host": ["{{baseUrl}}"],
          "path": ["auth", "login"]
        }
      }

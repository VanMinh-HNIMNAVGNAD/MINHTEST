    {
      "name": "TC06 - Thiếu trường dữ liệu (thiếu password)",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "// ════════════════════════════════════════════════",
              "// TC06: Thiếu trường dữ liệu - thiếu password",
              "// Input   : body = { \"username\": \"organizer\" }",
              "// Expected: 400 Bad Request, ErrorCode 1006 hoặc 1007",
              "// Ghi chú : @NotBlank trên password → MethodArgumentNotValidException",
              "//           → GlobalExceptionHandler map sang ErrorCode.PASSWORD_REQUIRED (1007)",
              "// Loại    : Bảo mật",
              "// ════════════════════════════════════════════════",
              "",
              "pm.test('TC06 | Status code là 400 Bad Request', function () {",
              "    pm.response.to.have.status(400);",
              "});",
              "",
              "pm.test('TC06 | Response body là JSON hợp lệ', function () {",
              "    pm.response.to.be.json;",
              "});",
              "",
              "const json = pm.response.json();",
              "",
              "pm.test('TC06 | code là 1007 (PASSWORD_REQUIRED) hoặc 1006 (USERNAME_REQUIRED)', function () {",
              "    pm.expect([1006, 1007]).to.include(json.code);",
              "});",
              "",
              "pm.test('TC06 | message không rỗng', function () {",
              "    pm.expect(json.message).to.be.a('string').and.not.empty;",
              "});",
              "",
              "pm.test('TC06 | result KHÔNG chứa token', function () {",
              "    pm.expect(json.result).to.be.undefined;",
              "});"
            ]
          }
        }

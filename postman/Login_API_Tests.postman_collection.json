{
  "info": {
    "name": "Auth - Đăng nhập (Login API)",
    "_postman_id": "auth-login-test-collection-v2",
    "description": "Bộ test case cho API POST /auth/login theo đúng bảng kiểm thử TC01–TC08",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080",
      "type": "string",
      "description": "Base URL của server backend"
    },
    {
      "key": "accessToken",
      "value": "",
      "type": "string",
      "description": "JWT token lưu sau khi đăng nhập thành công"
    }
  ],
  "item": [
    {
      "name": "TC01 - Đăng nhập thành công với thông tin hợp lệ",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "// ════════════════════════════════════════════════",
              "// TC01: Đăng nhập thành công với thông tin hợp lệ",
              "// Input   : username='admin', password='123456'",
              "// Expected: 200 OK, có token JWT",
              "// Loại    : Chức năng",
              "// ════════════════════════════════════════════════",
              "",
              "pm.test('TC01 | Status code là 200 OK', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('TC01 | Response body là JSON hợp lệ', function () {",
              "    pm.response.to.be.json;",
              "});",
              "",
              "const json = pm.response.json();",
              "",
              "pm.test('TC01 | code trả về là 1000 (thành công)', function () {",
              "    pm.expect(json.code).to.eql(1000);",
              "});",
              "",
              "pm.test('TC01 | result.token tồn tại và không rỗng', function () {",
              "    pm.expect(json.result).to.be.an('object');",
              "    pm.expect(json.result.token).to.be.a('string').and.have.length.above(10);",
              "});",
              "",
              "pm.test('TC01 | token có định dạng JWT (3 phần cách nhau bởi dấu chấm)', function () {",
              "    const parts = json.result.token.split('.');",
              "    pm.expect(parts).to.have.lengthOf(3);",
              "});",
              "",
              "// Decode JWT payload để kiểm tra claims",
              "const parts = json.result.token.split('.');",
              "if (parts.length === 3) {",
              "    try {",
              "        const payload = JSON.parse(atob(parts[1]));",
              "        console.log('JWT Payload:', JSON.stringify(payload, null, 2));",
              "",
              "        pm.test('TC01 | JWT payload chứa claim sub (username)', function () {",
              "            pm.expect(payload).to.have.property('sub');",
              "            pm.expect(payload.sub).to.eql('organizer');",
              "        });",
              "",
              "        pm.test('TC01 | JWT payload chứa claim exp và chưa hết hạn', function () {",
              "            pm.expect(payload).to.have.property('exp');",
              "            pm.expect(payload.exp).to.be.above(Math.floor(Date.now() / 1000));",
              "        });",
              "",
              "        pm.test('TC01 | JWT payload chứa claim scope (roles)', function () {",
              "            pm.expect(payload).to.have.property('scope');",
              "        });",
              "    } catch (e) {",
              "        console.log('Lỗi decode JWT:', e.message);",
              "    }",
              "}",
              "",
              "// Lưu token để dùng cho các test case khác",
              "if (json.result && json.result.token) {",
              "    pm.collectionVariables.set('accessToken', json.result.token);",
              "    console.log('Token đã lưu vào collectionVariables.accessToken');",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"username\": \"organizer\",\n    \"password\": \"Admin@123\"\n}",
          "options": { "raw": { "language": "json" } }
        },
        "url": {
          "raw": "{{baseUrl}}/auth/login",
          "host": ["{{baseUrl}}"],
          "path": ["auth", "login"]
        }
      }
    },
